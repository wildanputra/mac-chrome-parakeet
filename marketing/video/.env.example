# Voice configuration for the Kokoro-82M default pipeline.
# All values are optional — the script picks sane defaults.

# Voice preset. Defaults to "af_bella" (warm, calm, American female).
# Brand voice direction: calm, confident, minimal, slight warmth.
# Catalog (see scripts/generate-voice.ts for the full list):
#   af_bella, af_heart, af_sarah, af_nicole       — American female (calm)
#   am_michael, am_eric, am_onyx                  — American male (clear)
#   bf_emma, bf_alice                             — British female
#   bm_george, bm_daniel                          — British male
KOKORO_VOICE=

# Model precision. Lower = smaller/faster, higher = better quality.
# Options: fp32 | fp16 | q8 (default) | q4 | q4f16
KOKORO_DTYPE=

# Higgs Audio V2 premium-upgrade configuration (only used by `npm run voice:hq`).
# Defaults work for most users.
HIGGS_MODEL=
HIGGS_DEVICE=  # mps (Apple Silicon, default) | cpu | cuda

# Optional HuggingFace token for gated model access.
# Most local TTS models are open, but some emotion-controllable variants
# may require an HF account.
HF_TOKEN=
